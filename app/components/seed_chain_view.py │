def build_seed_chain(seed_df):

    nodes = []
    edges = []

    added_nodes = set()

    for _, row in seed_df.iterrows():

        source = str(row["Source_NodeID"])
        target = str(row["Target_NodeID"])

        if source not in added_nodes:
            nodes.append(
                Node(
                    id=source,
                    label=source,
                    size=30,
                    color="#ff4b4b"
                )
            )
            added_nodes.add(source)

        if target not in added_nodes:
            nodes.append(
                Node(
                    id=target,
                    label=target,
                    size=30,
                    color="#4b8bff"
                )
            )
            added_nodes.add(target)

        edges.append(
            Edge(
                source=source,
                target=target,
                label=row.get("Interaction", "")
            )
        )

    return nodes, edges
